<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        Repair CustomerSession storage in FrankenPHP worker mode.

        Scenario 1 — Reference break: Storage::_resetState() sets $_SESSION[$namespace] = &_data.
        session_start() replaces the Redis slot, breaking the reference. _data stays empty;
        getCustomerId() returns null despite the session holding the customer ID.

        Scenario 2 — Lazy startup: SessionRegistry::_resetState() clears the WeakMap so
        startSessions() is a no-op. The session has not been started; _data is empty from
        prior _resetState(). start() repairs both scenarios.

        FrontendConfig is injected as sessionConfig for CustomerSession so initIniOptions()
        always resets ini 'session.name' back to 'PHPSESSID', preventing contamination from
        adminhtml requests that call AdminConfig::initIniOptions() and set session.name='admin'
        globally in the PHP process. Without this fix, CustomerSession::start() reads
        $_COOKIE['admin'] instead of $_COOKIE['PHPSESSID'], loading the admin session as
        the customer session (corrupting both) or failing to load any session at all.

        The plugin also uses sessionConfig->getName() instead of session_name() for the
        lazy-startup cookie check, for the same reason.
    -->
    <type name="Magento\Customer\Model\Session">
        <arguments>
            <argument name="sessionConfig" xsi:type="object">MageOS\WorkerMode\Session\FrontendConfig</argument>
        </arguments>
        <plugin name="mage_os_worker_mode_customer_session_repair"
                type="MageOS\WorkerMode\Plugin\Customer\Model\CustomerSessionPlugin"/>
    </type>
    <type name="MageOS\WorkerMode\Plugin\Customer\Model\CustomerSessionPlugin">
        <arguments>
            <argument name="sessionConfig" xsi:type="object">MageOS\WorkerMode\Session\FrontendConfig</argument>
        </arguments>
    </type>

    <!--
        Guard the Registration block against a missing last_order_id in the checkout session.
        In FrankenPHP worker mode the session may not carry last_order_id when the success
        page renders, causing OrderRepository::get(0) to throw InputException and break the page.
        The plugin catches that exception and returns '' so the block is silently hidden.
    -->
    <type name="Magento\Checkout\Block\Registration">
        <plugin name="mage_os_worker_mode_checkout_registration_guard"
                type="MageOS\WorkerMode\Plugin\Checkout\Block\RegistrationPlugin"/>
    </type>

    <!--
        Last-resort recovery for DefaultConfigProvider::getConfig() in FrankenPHP worker mode.
        If CustomerSessionPlugin's early repair did not fire in time and getConfig() throws
        NoSuchEntityException because getCustomerId() returned null, this plugin repairs the
        CustomerSession via start(), clears the stale guest quote that getQuote() already cached,
        then retries getConfig() once so the correct customer quote is loaded from the database.
        CONTEXT_AUTH is never altered — manipulating it mid-render causes Hyvä reload loops.
    -->
    <type name="Magento\Checkout\Model\DefaultConfigProvider">
        <plugin name="mage_os_worker_mode_checkout_config_session_guard"
                type="MageOS\WorkerMode\Plugin\Checkout\Model\DefaultConfigProviderPlugin"/>
    </type>

    <!--
        Covers all callers of CheckoutSession::getQuote() for LockWaitException in FrankenPHP
        worker mode. Multiple workers may race to INSERT into quote_address for the same customer;
        the loser gets MySQL 1205. At that point isLoading=true and _quote=null — a plain retry
        throws LogicException("Infinite loop"). _resetState() resets those flags without touching
        quote_id; the competing worker has committed by then so the retry succeeds.
        Registered here (not just in DefaultConfigProviderPlugin) so that LoadCustomerQuoteObserver
        and any other caller of getQuote() is also protected. aroundGetQuote also calls start() so
        that CheckoutSession storage is populated from Redis before getQuoteId() is read.
    -->
    <type name="Magento\Checkout\Model\Session">
        <plugin name="mage_os_worker_mode_checkout_session_lock_wait_guard"
                type="MageOS\WorkerMode\Plugin\Checkout\Model\CheckoutSessionPlugin"/>
    </type>

    <!--
        Safety net: preserve last_real_order_id across the depersonalize clearStorage() call.

        In FrankenPHP worker mode, stale Layout _xml can cause DepersonalizeChecker to treat
        the checkout success page as cacheable, which triggers Checkout\DepersonalizePlugin to
        call clearStorage() and wipe _data before prepareBlockData() reads the order for the
        print-order button. Layout._resetState() now resets _xml to fix the root cause; this
        plugin is the safety net — on the success page it saves the order keys before the clear
        and restores them after, scoped to checkout_onepage_success only.
    -->
    <type name="Magento\Checkout\Model\Session">
        <plugin name="mage_os_worker_mode_checkout_preserve_order_data"
                type="MageOS\WorkerMode\Plugin\Checkout\Model\Session\PreserveOrderDataPlugin"/>
    </type>

    <!--
        Start CheckoutSession before SuccessValidator::isValid() reads magic-method data.

        isValid() calls getLastSuccessQuoteId(), getLastQuoteId() and getLastOrderId() — all
        __call magic methods that read Storage::getData() directly without triggering a session
        start. In FrankenPHP worker mode with startSessions() cleared, _data is empty at this
        point and all three calls return null, so every post-checkout visit redirects to the cart.

        Magento's plugin system does not support plugins on __call methods, so we plugin isValid()
        (explicit public method) and start the session in the before interceptor.
    -->
    <type name="Magento\Checkout\Model\Session\SuccessValidator">
        <plugin name="mage_os_worker_mode_checkout_success_session_start"
                type="MageOS\WorkerMode\Plugin\Checkout\Model\Session\SuccessValidatorPlugin"/>
    </type>
</config>
